<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmartDialer" parent="android:Theme.Material.Light.NoActionBar">
        <!-- We use Compose for styling, so this is just a base theme for the Activity -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme extends base theme with a splash background -->
    <style name="Theme.SmartDialer.Splash" parent="Theme.SmartDialer">
        <item name="android:windowBackground">@drawable/ic_launcher_background</item>
    </style>
</resources>
